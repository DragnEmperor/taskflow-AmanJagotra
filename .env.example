# Django — leave blank to auto-generate at container startup
DJANGO_SECRET_KEY=

# Database (PostgreSQL)
RDS_DB_NAME="greening_db"
RDS_PORT="5433"
RDS_USERNAME="postgres"
RDS_PASSWORD="admin001"
RDS_HOST="localhost"

# JWT RS256 Keys — leave blank to auto-generate at container startup
# For production, set these explicitly:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 > private.pem
#   openssl pkey -in private.pem -pubout > public.pem
JWT_SIGNING_KEY=
JWT_VERIFICATION_KEY=

# CORS
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:4000"
CSRF_TRUSTED_ORIGINS="http://localhost:3000,http://localhost:4000"

ALLOWED_HOSTS="*"
DEVELOPMENT=true